{
    "name": "@gravity-ui/readme-validator",
    "version": "1.1.0",
    "description": "Parse and validate README files against the Gravity UI LLM-ready template.",
    "license": "MIT",
    "type": "module",
    "main": "dist/index.js",
    "bin": {
        "gravity-readme": "dist/cli.js"
    },
    "files": [
        "dist",
        "TEMPLATE.md",
        "TEMPLATE.component.md"
    ],
    "scripts": {
        "typecheck": "tsc",
        "build": "npm run lint && npm run typecheck && npm run build:lib && npm run build:cli && npm run build:action",
        "build:lib": "esbuild src/index.ts --bundle --platform=node --target=node24 --format=esm --packages=external --outfile=dist/index.js",
        "build:cli": "esbuild src/cli.ts --bundle --platform=node --target=node24 --format=esm --packages=external --outfile=dist/cli.js",
        "build:action": "esbuild src/action.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/action.cjs",
        "test": "NODE_OPTIONS=--experimental-vm-modules jest",
        "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
        "lint": "eslint . --ext .ts",
        "lint:fix": "eslint . --ext .ts --fix",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "mdast-util-to-string": "^3.1.1",
        "remark-gfm": "^3.0.1",
        "remark-parse": "^10.0.1",
        "unified": "^10.1.2"
    },
    "devDependencies": {
        "@actions/core": "^1.10.1",
        "@actions/github": "^6.0.0",
        "@actions/glob": "^0.4.0",
        "@gravity-ui/eslint-config": "^3.1.1",
        "@gravity-ui/tsconfig": "^1.0.0",
        "@types/jest": "^29.5.12",
        "@types/mdast": "^3.0.11",
        "@types/node": "^24.0.0",
        "@typescript-eslint/eslint-plugin": "^6.10.0",
        "@typescript-eslint/parser": "^6.10.0",
        "esbuild": "^0.19.5",
        "eslint": "^8.53.0",
        "eslint-config-prettier": "^9.0.0",
        "eslint-plugin-import": "^2.29.0",
        "eslint-plugin-prettier": "^5.0.1",
        "jest": "^29.7.0",
        "prettier": "^3.0.0",
        "ts-jest": "^29.1.1",
        "typescript": "^5.2.2"
    }
}
